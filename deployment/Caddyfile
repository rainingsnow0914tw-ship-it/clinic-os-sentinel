# ============================================================
# Sentinel Caddy reverse proxy + frontend static serve
# 自動 Let's Encrypt SSL (要 domain 對 ECS 公網 IP 解析)
# ============================================================

{
    email {$CADDY_EMAIL}
}

{$DOMAIN} {
    encode gzip zstd

    # Phase 8 安全: 限 request body 1MB (防大 payload attack)
    request_body {
        max_size 1MB
    }

    # API: axios baseURL = /api → strip 後 backend 收 /v1/...
    handle_path /api/* {
        reverse_proxy backend:8080
    }

    # 直接打的 backend 路徑 (curl/judge debug)
    handle /v1/* {
        reverse_proxy backend:8080
    }

    # frontend SPA: serve dist + try_files fallback 給 React Router
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    log {
        output stdout
        format console
    }
}
