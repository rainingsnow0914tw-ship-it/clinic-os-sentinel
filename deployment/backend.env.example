# ============================================================
# Sentinel backend container env (deployment 端)
# ============================================================
# 複製成 backend.env，填好實值，不要 commit
# DATABASE_URL 由 compose top-level .env 注入，不寫這
# ============================================================

APP_ENV=production
LOG_LEVEL=INFO
API_PREFIX=/v1
API_TITLE=Clinic OS Sentinel API

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === Firebase (hackathon: bypass) ===
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# === Qwen / DashScope (Alibaba Cloud LLM service) ===
DASHSCOPE_API_KEY=請貼 hackathon DashScope key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_TEXT_MODEL=qwen3.7-max
QWEN_VISION_MODEL=qwen3.7-plus
QWEN_ASR_MODEL=paraformer-v2
QWEN_REQUEST_TIMEOUT=120
QWEN_MAX_RETRIES=2

# === Sentinel ===
SENTINEL_ENABLED=true
SENTINEL_DEV_BYPASS_AUTH=true

# === CORS (frontend OSS bucket URL，多個用 comma) ===
# 例: https://sentinel-demo.oss-ap-southeast-1.aliyuncs.com,https://sentinel-demo.fayumacau.com
CORS_ORIGINS=https://sentinel-demo.oss-ap-southeast-1.aliyuncs.com

# === 其他 AI provider (hackathon 用不到，空著) ===
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
