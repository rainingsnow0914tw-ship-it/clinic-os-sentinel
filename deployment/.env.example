# ============================================================
# Sentinel 阿里雲部署 — top-level compose .env
# ============================================================
# 複製成 .env，填好實值，**不要 commit 進 git**
# .env 已在 deployment/.gitignore
# ============================================================

# === Caddy / domain ===
# 例: sentinel.fayumacau.com
# 必須先在 DNS 把這個 domain 的 A record 指向 ECS 公網 IP
DOMAIN=sentinel.fayumacau.com
CADDY_EMAIL=rainingsnow0914@gmail.com

# === PostgreSQL ===
PG_DB=clinic_os
PG_USER=clinic
PG_PASSWORD=請改一個強密碼

# === backend secret 在 deployment/backend.env ===
# (見 backend.env.example)
