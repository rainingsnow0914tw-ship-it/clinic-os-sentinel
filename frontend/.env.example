# 前端環境變數範例
# 複製成 .env.local 並填入實際值（.env.local 不會進 git）
#
# Vite 規則：只有 VITE_ 開頭的變數會被 bundle 進 client side

# Backend API base URL
# 開發環境：留空，由 vite.config.ts 的 proxy 處理 /api → localhost:8080
# 正式環境：填 Cloud Run URL，例如 https://clinic-os-backend-xxx.a.run.app
VITE_API_BASE_URL=

# Firebase 設定（從 Firebase Console → Project Settings → Web app 拿）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
