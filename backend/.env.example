# ============================================================
# Clinic OS Backend — Environment Variables
# ============================================================
# 複製這份到 .env，填入實際值
# .env 不可進 git（已在 .gitignore）
# 生產環境用 Secret Manager + Cloud Run env vars
# ============================================================

# === 環境 ===
APP_ENV=development                              # development / staging / production
LOG_LEVEL=INFO                                   # DEBUG / INFO / WARNING / ERROR

# === 資料庫 ===
# 本地開發：postgresql://user:pass@localhost:5432/clinic_os
# Cloud Run + Cloud SQL：postgresql+psycopg://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+psycopg://clinic:clinic_dev_pw@localhost:5432/clinic_os
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === Firebase Auth ===
# 從 Firebase Console > Project settings > Service accounts 下載 JSON
FIREBASE_PROJECT_ID=clinic-os-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-admin-sa.json

# === GCS（PDF storage） ===
GCS_BUCKET_NAME=clinic-os-pdfs-prod
GCS_PDF_URL_EXPIRY_SECONDS=3600                  # signed URL 1 小時

# === AI Providers ===
# 注意：model 名字會變動，實際使用前必先 web_search 確認
# Gemini
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash            # 待確認 - 用前要 web_search 最新版本
# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini                 # 待確認
# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001  # 待確認

# === CORS ===
# 開發：http://localhost:5173
# 生產：https://clinic-os.web.app,https://clinic-os.firebaseapp.com
CORS_ORIGINS=http://localhost:5173

# === API ===
API_PREFIX=/v1
API_TITLE=Clinic OS API
