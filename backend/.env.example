# ============================================================
# Clinic OS + Sentinel Backend -- Environment Variables
# ============================================================
# Copy this file to .env and fill in actual values.
# .env is gitignored. Use Secret Manager / Alibaba Cloud KMS in production.
#
# IMPORTANT for Windows users:
#   Edit .env with VS Code or Notepad++, NOT Notepad.
#   Notepad on Windows may save as ANSI (CP950 / Big5 in zh-TW locale),
#   which crashes pydantic-settings (utf-8 only). All comments here are
#   plain ASCII to make Notepad save safely if you must use it.
# ============================================================

# === Environment ===
APP_ENV=development                              # development / staging / production
LOG_LEVEL=INFO                                   # DEBUG / INFO / WARNING / ERROR

# === Database ===
# Sentinel local demo (SQLite, zero deps):
#   sqlite:///./clinic_os_sentinel.db
# Local PostgreSQL:
#   postgresql+psycopg://user:pass@localhost:5432/clinic_os
# Alibaba Cloud RDS:
#   postgresql+psycopg://USER:PASS@HOST:5432/DB
DATABASE_URL=sqlite:///./clinic_os_sentinel.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === Firebase Auth ===
# Hackathon dev mode: leave both empty (paired with SENTINEL_DEV_BYPASS_AUTH=true).
# Production: download service-account JSON from Firebase Console.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# === Cloud Storage (PDF storage, not used during hackathon) ===
GCS_BUCKET_NAME=clinic-os-pdfs-prod
GCS_PDF_URL_EXPIRY_SECONDS=3600                  # signed URL expiry (1h)

# === Qwen / DashScope (Sentinel primary LLM during hackathon) ===
# International endpoint: dashscope-intl.aliyuncs.com
# Verified 2026-06-26 03:00: qwen3.7-max works.
DASHSCOPE_API_KEY=                               # paste your Alibaba Cloud key here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_TEXT_MODEL=qwen3.7-max                      # 1M context, agent frontier (2026-05 GA)
QWEN_VISION_MODEL=qwen3.7-plus                   # multimodal (X-ray, lab report photos)
QWEN_ASR_MODEL=paraformer-v2                     # TODO: verify exact ID before use

# === Sentinel ===
SENTINEL_ENABLED=true
SENTINEL_DEV_BYPASS_AUTH=true                    # local demo + judge test access; MUST be false in production

# === Other AI Providers (post-hackathon Chloe clinic version only) ===
# Note: model names change. Always web_search before hardcoding.
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# === CORS ===
# Dev: http://localhost:5173
# Prod: comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173

# === API ===
API_PREFIX=/v1
API_TITLE=Clinic OS API
